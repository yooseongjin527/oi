# ============================================
# OI Project - Environment Variables Template
# ============================================
# 이 파일을 복사해서 .env로 만들고 실제 값 채우세요:
#   cp .env.example .env

# ─── PostgreSQL ───────────────────────────────
POSTGRES_USER=oi_user
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=oi
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── FastAPI / JWT ────────────────────────────
# 실제 값은 openssl rand -hex 32 로 생성해서 넣을 것
JWT_SECRET_KEY=change_me_to_random_64_hex_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 초기 admin 계정 (init_admin.py가 사용)
ADMIN_EMAIL=admin@oi.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# ─── GitHub API (Collector) ───────────────────
# Public 엔드포인트라 토큰 없어도 동작하지만
# 토큰 있으면 rate limit이 60/h → 5000/h로 올라감
GITHUB_TOKEN=

# ─── Redpanda / Kafka ─────────────────────────
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_TOPIC_LIVE=gh.events.live

# ─── AWS (Day 2부터 사용) ─────────────────────
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=oi-data-lake
# 로컬에서는 AWS CLI profile 또는 키, EC2에서는 IAM Role 사용
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Bedrock (Day 5부터 사용) ─────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# ─── Admin Console (Streamlit) ───────────────
# 빈 문자열 = 모든 IP 허용 (로컬 개발 모드)
# 운영에서는 콤마 구분으로 EC2 본인 IP, 회사 IP 등 명시
ADMIN_IP_WHITELIST=

# --- Airflow ---
AIRFLOW_UID=1000
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=CHANGEME
AIRFLOW_DB_NAME=airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGEME
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_FERNET_KEY=GENERATE_WITH_python_-c_from_cryptography.fernet_import_Fernet_print_Fernet.generate_key().decode()

# --- Athena / Glue ---
ATHENA_WORKGROUP=oi-workgroup
GLUE_DATABASE=oi
