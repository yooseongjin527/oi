# ============================================
# OI Project — Environment Variables Template
# ============================================
# 1. cp .env.example .env
# 2. 아래 모든 값을 실제 값으로 채우기
# 3. JWT_SECRET_KEY 는: openssl rand -hex 32
# 4. AIRFLOW_FERNET_KEY 는:
#      python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ─── PostgreSQL ───────────────────────────────
POSTGRES_USER=oi_user
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=oi
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── FastAPI / JWT ────────────────────────────
JWT_SECRET_KEY=change_me_to_random_64_hex_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 초기 admin 계정 (init_admin.py 가 사용)
ADMIN_EMAIL=admin@oi.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# ─── GitHub API (Collector) ───────────────────
# 토큰 없으면 60/h, 있으면 5000/h
GITHUB_TOKEN=

# ─── Redpanda / Kafka ─────────────────────────
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_TOPIC_LIVE=gh.events.live

# ─── AWS ──────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=oi-data-lake
# 로컬: AWS CLI profile 또는 키. EC2: IAM Role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Athena / Glue ────────────────────────────
OI_GLUE_DATABASE=oi
OI_ATHENA_WORKGROUP=oi-workgroup
OI_ATHENA_OUTPUT=s3://oi-data-lake/athena-results/

# ─── Bedrock ──────────────────────────────────
OI_BEDROCK_REGION=ap-northeast-2
OI_BEDROCK_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0

# ─── OpenSearch ───────────────────────────────
# 도커 컴포즈 내부 통신용 호스트명
OI_OPENSEARCH_HOST=http://opensearch:9200

# ─── Admin Console (Streamlit) ────────────────
# 빈 문자열 = 모든 IP 허용 (로컬 개발 모드)
# 운영: 콤마 구분으로 EC2 본인 IP 등 명시 (예: "127.0.0.1,1.2.3.4")
ADMIN_IP_WHITELIST=

# ─── Airflow ──────────────────────────────────
AIRFLOW_UID=1000
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=CHANGEME
AIRFLOW_DB_NAME=airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGEME
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_FERNET_KEY=GENERATE_WITH_python_-c_from_cryptography.fernet_import_Fernet_print_Fernet.generate_key().decode()